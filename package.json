{
  "name": "cute-survivor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:gh": "BASE_PATH=/cute-survivor/ vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm typecheck && pnpm lint && pnpm format && pnpm test"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/three": "^0.160.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.0.10",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@10.23.0"
}
